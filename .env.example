# SPA URL the browser uses (Vite dev, production site, etc.). Added to CORS allowlist.
# Example:
# FRONTEND_URL=http://localhost:5173

# Optional: more origins, comma-separated (merged with FRONTEND_URL and dev defaults).
# CORS_ORIGIN=http://localhost:5173,https://app.example.com

PORT=3000
MONGO_URI=
JWT_SECRET_KEY=
